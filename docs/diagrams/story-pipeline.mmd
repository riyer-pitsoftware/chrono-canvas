flowchart LR
    INPUT(["Text / Voice / Image"])

    subgraph Pipeline["Story Pipeline — 13 Nodes"]
        direction LR
        ORCH["1. Story<br/>Orchestrator"]
        I2S["2. Image-to-Story<br/><small>optional · Gemini vision</small>"]
        REF["3. Reference<br/>Analysis<br/><small>optional · Gemini vision</small>"]
        CHAR["4. Character<br/>Extraction"]
        DECOMP["5. Scene<br/>Decomposition<br/><small>3–8 scenes</small>"]
        RESEARCH["6. Historical<br/>Research<br/><small>Google Search grounding</small>"]
        PROMPT["7. Scene Prompt<br/>Generation<br/><small>parallel</small>"]
        VALID["8. Prompt<br/>Pre-Validation<br/><small>auto-repair < 0.7</small>"]
        IMG["9. Scene Image<br/>Generation<br/><small>parallel · Imagen 4</small>"]
        COH["10. Storyboard<br/>Coherence<br/><small>Gemini multimodal</small>"]
        NAR["11. Narration<br/>Script<br/><small>vision-enhanced</small>"]
        AUDIO["12. Narration<br/>Audio<br/><small>Gemini TTS · parallel</small>"]
        VIDEO["13. Video<br/>Assembly<br/><small>optional · ffmpeg</small>"]
        EXP["14. Storyboard<br/>Export"]
    end

    OUTPUT(["Storyboard + Audio +<br/>Video + Citations"])

    INPUT --> ORCH --> I2S --> REF --> CHAR --> DECOMP --> RESEARCH --> PROMPT --> VALID --> IMG --> COH --> NAR --> AUDIO --> VIDEO --> EXP --> OUTPUT

    %% Coherence regen loop
    COH -->|"regen worst scenes<br/>if char_consistency < 0.6"| PROMPT

