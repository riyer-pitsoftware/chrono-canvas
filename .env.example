# ChronoCanvas Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Per-task LLM routing defaults live in backend/src/chronocanvas/llm/router.py
# (DEFAULT_ROUTING dict). Override DEFAULT_LLM_PROVIDER here to change the
# global fallback; edit router.py to change per-task assignments.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://chronocanvas:chronocanvas@localhost:5432/chronocanvas

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM Providers ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SERPAPI_KEY=

# ── LLM Routing ───────────────────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
CLAUDE_MODEL=claude-sonnet-4-5-20250929
OPENAI_MODEL=gpt-4o

# ── Image Generation ──────────────────────────────────────────────────────────
IMAGE_PROVIDER=mock
SD_API_URL=http://localhost:7860
COMFYUI_API_URL=http://localhost:8188
COMFYUI_MODEL=sdxl
COMFYUI_SDXL_CHECKPOINT=juggernautXL_v9.safetensors
FACEFUSION_API_URL=http://localhost:7861

# ── Facial Compositing (FaceFusion) ───────────────────────────────────────────
# Set FACEFUSION_ENABLED=true to use the real FaceFusion service for face
# compositing. When false, face compositing uses a mock overlay (development).
# This is independent of IMAGE_PROVIDER — you can use ComfyUI for image
# generation and FaceFusion for face compositing simultaneously.
FACEFUSION_ENABLED=false
# Absolute path to a local clone of https://github.com/facefusion/facefusion
# Required when FACEFUSION_ENABLED=true; the directory is bind-mounted
# into the facefusion Docker service at /facefusion.
# Example: FACEFUSION_SOURCE_PATH=/home/yourname/code/facefusion
FACEFUSION_SOURCE_PATH=

# ── Pipeline Toggles (eval conditions) ────────────────────────────────────────
# When false, validation still runs and scores but never triggers the
# regenerate loop (prompt_generation → image_generation → validation retry).
VALIDATION_RETRY_ENABLED=true
# When false, face_search node is skipped entirely (no SerpAPI calls).
FACE_SEARCH_ENABLED=true

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED in production — app refuses to start with the default value.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production

# ── Content Moderation ────────────────────────────────────────────────────────
CONTENT_MODERATION_ENABLED=true

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output

# ── Research Cache (pgvector + sentence-transformers) ─────────────────────────
RESEARCH_CACHE_ENABLED=true
RESEARCH_CACHE_THRESHOLD=0.85
RESEARCH_CACHE_MODEL=all-MiniLM-L6-v2

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=60
LLM_MAX_CONCURRENT=5

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
