# HistoryLens Environment Configuration

# Database
DATABASE_URL=postgresql+asyncpg://historylens:historylens@localhost:5432/historylens

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Providers
OLLAMA_BASE_URL=http://localhost:11434
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# LLM Routing
DEFAULT_LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
CLAUDE_MODEL=claude-sonnet-4-5-20250929
OPENAI_MODEL=gpt-4o

# Image Generation
IMAGE_PROVIDER=mock
SD_API_URL=http://localhost:7860
FACEFUSION_API_URL=http://localhost:7861

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# Security
SECRET_KEY=change-me-in-production

# Storage
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output

# Rate Limiting
RATE_LIMIT_RPM=60
LLM_MAX_CONCURRENT=5

# Logging
LOG_LEVEL=INFO
